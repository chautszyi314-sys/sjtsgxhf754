<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>图片全屏上传显示</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #f5f7fa;
        }

        /* 上传容器样式 */
        .upload-container {
            text-align: center;
            background: white;
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            transition: transform 0.2s;
        }

        .upload-container:hover {
            transform: translateY(-2px);
        }

        /* 隐藏原生文件输入框 */
        #file-input {
            display: none;
        }

        /* 自定义上传按钮，使用你提供的图标 */
        .upload-btn {
            display: inline-block;
            cursor: pointer;
        }

        .icon-img {
            width: 120px;
            height: 120px;
            border-radius: 24px;
            box-shadow: 0 8px 16px rgba(0, 130, 255, 0.2);
            transition: all 0.2s;
        }

        .icon-img:hover {
            box-shadow: 0 12px 24px rgba(0, 130, 255, 0.3);
            filter: brightness(1.05);
        }

        .upload-text {
            margin-top: 15px;
            font-size: 16px;
            color: #333;
            font-weight: 500;
        }

        /* 全屏遮罩层样式 */
        #fullscreen-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: #000;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            cursor: pointer;
        }

        /* 全屏显示的图片 */
        #fullscreen-img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }
    </style>
</head>
<body>

    <div class="upload-container">
        <input type="file" id="file-input" accept="image/*">
        
        <label for="file-input" class="upload-btn">
            <img class="icon-img" src="data:image/jpeg;base64," alt="上传图标">
            <div class="upload-text">点击图标上传图片</div>
        </label>
    </div>

    <div id="fullscreen-overlay">
        <img id="fullscreen-img" src="" alt="全屏图片">
    </div>

    <script>
        const fileInput = document.getElementById('file-input');
        const fullscreenOverlay = document.getElementById('fullscreen-overlay');
        const fullscreenImg = document.getElementById('fullscreen-img');

        // 监听文件上传
        fileInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                // 读取文件并转换为URL
                const reader = new FileReader();
                reader.onload = function(event) {
                    fullscreenImg.src = event.target.result;
                    
                    // 显示全屏遮罩层
                    fullscreenOverlay.style.display = 'flex';
                    
                    // 触发浏览器的标准全屏API（可选，能隐藏浏览器地址栏）
                    launchIntoFullscreen(fullscreenOverlay);
                };
                reader.readAsDataURL(file);
            }
